# Backend (.env)
AI_PROVIDER=huggingface
AI_MODEL=Qwen/Qwen2.5-7B-Instruct
AI_BASE_URL=https://router.huggingface.co/v1
OPENAI_API_KEY=hf_your_huggingface_token_here
DATABASE_URL=sqlite:///./portfolios.db
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3005

# Frontend (.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PORTFOLIO_URL=http://localhost:3005

# ============================================
# After Deployment, change to:
# ============================================

# Backend (.env) - Production
# AI_PROVIDER=huggingface
# AI_MODEL=Qwen/Qwen2.5-7B-Instruct
# AI_BASE_URL=https://router.huggingface.co/v1
# OPENAI_API_KEY=hf_your_huggingface_token_here
# DATABASE_URL=postgresql://...  (from Railway)

# Frontend (.env.local) - Production (Vercel)
# NEXT_PUBLIC_API_URL=https://api.myportfolio.com
# NEXT_PUBLIC_PORTFOLIO_URL=https://myportfolio.com
