# Backend (.env)
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:7b-instruct
# Docker backend -> use host.docker.internal
# Local backend (no Docker) -> use http://localhost:11434/v1
AI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=
DATABASE_URL=sqlite:///./portfolios.db
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3005

# Frontend (.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PORTFOLIO_URL=http://localhost:3005

# ============================================
# After Deployment, change to:
# ============================================

# Backend (.env) - Production
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=
# OPENAI_API_KEY=your-openai-api-key-here
# DATABASE_URL=postgresql://...  (from Railway)

# Frontend (.env.local) - Production (Vercel)
# NEXT_PUBLIC_API_URL=https://api.myportfolio.com
# NEXT_PUBLIC_PORTFOLIO_URL=https://myportfolio.com
